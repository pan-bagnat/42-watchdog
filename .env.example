###############################################################################
# Access control
###############################################################################
ACCESS_CONTROL_ENDPOINT=https://ca.42nice.fr/api
ACCESS_CONTROL_TESTPATH=/events/?length=1
ACCESS_CONTROL_USERNAME=YOUR_CA_USERNAME
ACCESS_CONTROL_PASSWORD=YOUR_CA_PASSWORD

###############################################################################
# 42 API v2
###############################################################################
FT_V2_TOKEN_URL=https://api.intra.42.fr/oauth/token
FT_V2_ENDPOINT=https://api.intra.42.fr/v2
FT_V2_TESTPATH=/campus/41
FT_V2_UID=YOUR_42API_APP_UID
FT_V2_SECRET=YOUR_42API_APP_TOKEN
FT_V2_SCOPE=public
FT_V2_CAMPUS_ID=41
FT_V2_APPRENTICE_PROJECTS=2561,2562,2563,2564

###############################################################################
# 42 attendance / Chronos
###############################################################################
FT_ATTENDANCE_AUTO_POST=false
FT_ATTENDANCE_TOKEN_URL=https://auth.42.fr/auth/realms/staff-42/protocol/openid-connect/token
FT_ATTENDANCE_ENDPOINT=https://chronos.42.fr/api/v1
FT_ATTENDANCE_TESTPATH=/campuses/41/sources
FT_ATTENDANCE_UID=YOUR_42API_APP_UID
FT_ATTENDANCE_SECRET=YOUR_42API_APP_TOKEN
FT_ATTENDANCE_USERNAME=YOUR_42STAFF_USERNAME
FT_ATTENDANCE_PASSWORD=YOUR_42STAFF_PASSWORD

###############################################################################
# 42 CFA
###############################################################################
FT_CFA_TOKEN_URL=https://auth.42.fr/auth/realms/staff-42/protocol/openid-connect/token
FT_CFA_ENDPOINT=https://cfa.42.fr/api/v1
FT_CFA_TESTPATH=/cfa_staff/me
FT_CFA_UID=YOUR_42API_APP_UID
FT_CFA_SECRET=YOUR_42API_APP_TOKEN
FT_CFA_USERNAME=YOUR_42STAFF_USERNAME
FT_CFA_PASSWORD=YOUR_42STAFF_PASSWORD

###############################################################################
# Mailer
###############################################################################
MAILER_SMTP_SERVER=smtp-relay.gmail.com
MAILER_SMTP_PORT=587
MAILER_SMTP_AUTH=false
MAILER_SMTP_USER=
MAILER_SMTP_PASS=
MAILER_SMTP_TLS=true
MAILER_HELO=pedago.42nice.fr
MAILER_FROM_NAME=Watchdog
MAILER_FROM_MAIL=pedago.watchdog.noreply@42nice.fr
MAILER_RECIPIENTS=heinz@42nice.fr

###############################################################################
# Webhook security
###############################################################################
WEBHOOK_SECRET=CHANGE_ME

###############################################################################
# Authentication
###############################################################################
# Public hostname used by the local auth service callbacks/cookies.
HOST_NAME=localhost

# AUTH_MODE defaults to `local` when unset.
# local: backend trusts a local auth service exposed at AUTH_SERVICE_URL
# panbagnat: backend trusts Pan Bagnat directly for session and user lookup
AUTH_MODE=local

# Local auth service mode.
# These values are also consumed by the `auth`, `auth-db`, and `auth-migrator`
# services from docker compose.
AUTH_SERVICE_URL=http://auth:8080
POSTGRES_USER=watchdog_auth
POSTGRES_PASSWORD=watchdog_auth
POSTGRES_DB=watchdog_auth
POSTGRES_URL=postgresql://watchdog_auth:watchdog_auth@auth-db:5432/watchdog_auth?sslmode=disable
FT_CLIENT_ID=YOUR_42_OAUTH_CLIENT_ID
FT_CLIENT_SECRET=YOUR_42_OAUTH_CLIENT_SECRET
FT_CALLBACK_URL=http://localhost/auth/42/callback
ADMIN_LOGINS=heinz
SESSION_COOKIE_SAME_SITE=lax

# Pan Bagnat mode
AUTH_PANBAGNAT_URL=https://panbagnat.42nice.fr
AUTH_PANBAGNAT_LOGIN_URL=
AUTH_PANBAGNAT_SKIP_VERIFY=false
AUTH_ADMIN_ROLES=roles_admin

###############################################################################
# Database (auth)
###############################################################################
AUTH_POSTGRES_USER=${POSTGRES_USER}
AUTH_POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
AUTH_POSTGRES_HOST=auth-db
AUTH_POSTGRES_PORT=5432
AUTH_POSTGRES_DB=watchdog_auth
AUTH_POSTGRES_URL=postgres://${AUTH_POSTGRES_USER}:${AUTH_POSTGRES_PASSWORD}@${AUTH_POSTGRES_HOST}:${AUTH_POSTGRES_PORT}/${AUTH_POSTGRES_DB}?sslmode=disable
