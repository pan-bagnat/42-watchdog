###############################################################################
# Access control
###############################################################################
ACCESS_CONTROL_ENDPOINT=https://ca.42nice.fr/api
ACCESS_CONTROL_TESTPATH=/events/?length=1
ACCESS_CONTROL_USERNAME=YOUR_CA_USERNAME
ACCESS_CONTROL_PASSWORD=YOUR_CA_PASSWORD

###############################################################################
# 42 API v2
###############################################################################
FT_V2_TOKEN_URL=https://api.intra.42.fr/oauth/token
FT_V2_ENDPOINT=https://api.intra.42.fr/v2
FT_V2_TESTPATH=/campus/41
FT_V2_UID=YOUR_42API_APP_UID
FT_V2_SECRET=YOUR_42API_APP_TOKEN
FT_V2_SCOPE=public
FT_V2_CAMPUS_ID=41
FT_V2_APPRENTICE_PROJECTS=2561,2562,2563,2564

###############################################################################
# 42 attendance / Chronos
###############################################################################
FT_ATTENDANCE_AUTO_POST=false
FT_ATTENDANCE_TOKEN_URL=https://auth.42.fr/auth/realms/staff-42/protocol/openid-connect/token
FT_ATTENDANCE_ENDPOINT=https://chronos.42.fr/api/v1
FT_ATTENDANCE_TESTPATH=/campuses/41/sources
FT_ATTENDANCE_UID=YOUR_42API_APP_UID
FT_ATTENDANCE_SECRET=YOUR_42API_APP_TOKEN
FT_ATTENDANCE_USERNAME=YOUR_42STAFF_USERNAME
FT_ATTENDANCE_PASSWORD=YOUR_42STAFF_PASSWORD

###############################################################################
# Mailer
###############################################################################
MAILER_SMTP_SERVER=smtp-relay.gmail.com
MAILER_SMTP_PORT=587
MAILER_SMTP_AUTH=false
MAILER_SMTP_USER=
MAILER_SMTP_PASS=
MAILER_SMTP_TLS=true
MAILER_HELO=pedago.42nice.fr
MAILER_FROM_NAME=Watchdog
MAILER_FROM_MAIL=pedago.watchdog.noreply@42nice.fr
MAILER_RECIPIENTS=heinz@42nice.fr

###############################################################################
# Webhook security
###############################################################################
WEBHOOK_SECRET=CHANGE_ME

###############################################################################
# Panbagnat authentication for remote /commands
###############################################################################
AUTH_MODE=panbagnat
AUTH_PANBAGNAT_URL=https://panbagnat.42nice.fr
AUTH_PANBAGNAT_SKIP_VERIFY=false
AUTH_ADMIN_ROLES=roles_admin
